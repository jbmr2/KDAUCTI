rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: players
    // Fields: name, category, position, basePrice, currentBid, currentBidderId, status, teamId, stats
    //
    // Collection: teams
    // Fields: name, ownerId, budget, totalPlayers, logo
    //
    // Collection: bids
    // Fields: playerId, teamId, amount, timestamp
    //
    // Collection: auctionState
    // Fields: currentPlayerId, status, timer
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jbmrsports@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPlayer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category in ['A', 'B', 'C'] &&
             data.position in ['Raider', 'Defender', 'All-rounder'] &&
             data.basePrice is number && data.basePrice >= 0 &&
             data.status in ['unsold', 'sold', 'current'];
    }

    function isValidTeam(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.budget is number && data.budget >= 0;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow updates for bidding if authenticated
      allow update: if isAuthenticated() && 
                    (isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBid', 'currentBidderId'])));
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /bids/{bidId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete, update: if isAdmin();
    }

    match /auctionState/{stateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
